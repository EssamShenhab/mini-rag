POSTGRES_PASSWORD="270539"
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_MAIN_DATABASE="minirag"

# ========================= LLM Config =========================
GENERATION_BACKEND = "OPENAI"
EMBEDDING_BACKEND = "JINA"

OPENAI_API_KEY=""
COHERE_API_KEY=""
JINA_API_KEY=""
OPENAI_API_URL="http://localhost:11434/v1/"

GENERATION_MODEL_ID_LITERAL = ["qwen2.5:1.5b-instruct-q4_K_M", "gemma2:9b-instruct-q5_0", "qcwind/qwen2.5-7B-instruct-Q4_K_M", "gpt-4o-mini"]
GENERATION_MODEL_ID = "qcwind/qwen2.5-7B-instruct-Q4_K_M"
